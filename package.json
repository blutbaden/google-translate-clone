{
  "name": "google-translate-clone",
  "version": "1.0.0",
  "scripts": {
    "ng": "node -r dotenv/config ./node_modules/.bin/ng",
    "start": "node -r dotenv/config ./node_modules/.bin/ng serve",
    "build": "node -r dotenv/config ./node_modules/.bin/ng build",
    "watch": "node -r dotenv/config ./node_modules/.bin/ng build --watch --configuration development",
    "test": "node -r dotenv/config ./node_modules/.bin/ng test"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@angular/animations": "^21.2.16",
    "@angular/common": "^21.2.16",
    "@angular/compiler": "^21.2.16",
    "@angular/core": "^21.2.16",
    "@angular/forms": "^21.2.16",
    "@angular/platform-browser": "^21.2.16",
    "@angular/platform-browser-dynamic": "^21.2.16",
    "@angular/router": "^21.2.16",
    "bootstrap": "^5.3.8",
    "ngx-toastr": "^20.0.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "overrides": {
    "uuid": ">=11.1.1",
    "webpack-dev-server": ">=5.2.4",
    "axios": ">=1.8.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.16",
    "@ngx-env/builder": "^21.0.1",
    "@types/jasmine": "~5.1.0",
    "dotenv": "^17.4.2",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}
